# Normalize line endings to LF on commit; checkout as LF everywhere.
* text=auto eol=lf

# Windows batch files must use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — never touch line endings.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.sqlite binary
*.node  binary
