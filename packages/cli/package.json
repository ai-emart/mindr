{
  "name": "mindr",
  "version": "0.0.1",
  "description": "Give AI coding agents persistent memory of your codebase — decisions, conventions, bugs, and debt that compound over time",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mindr": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": ["ai", "coding-agent", "memory", "codebase", "mcp", "claude-code", "codex", "cursor", "aider", "llm", "git", "tree-sitter", "developer-tools"],
  "license": "MIT",
  "author": "ai-emart",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-emart/mindr"
  },
  "homepage": "https://github.com/ai-emart/mindr#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-emart/mindr": "workspace:*",
    "@ai-emart/mindr-core": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^7.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@remembr/sdk": "^0.2.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^14.0.3"
  }
}
