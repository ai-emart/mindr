{
  "name": "mindr",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mindr": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-emart/mindr": "workspace:*",
    "@ai-emart/mindr-core": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^7.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@remembr/sdk": "^0.2.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^14.0.3"
  }
}
